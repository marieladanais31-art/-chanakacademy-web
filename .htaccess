Options -Indexes

# Bloquear acceso publico a documentacion interna del repositorio.
<FilesMatch "\.(md|lock|yml|yaml)$">
  Require all denied
</FilesMatch>
<FilesMatch "^\.(git|htaccess|gitignore)">
  Require all denied
</FilesMatch>

RewriteEngine On

# Version canonica unica: https + www
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://www.%1%{REQUEST_URI} [R=301,L]

# Carpeta privada (leads, logs, claves): nunca accesible desde la web.
RewriteRule ^_private(/|$) - [F,L]

# Redirecciones 301 desde URLs antiguas hacia las rutas nuevas.
RewriteRule ^dossier-offcampus\.html$ /off-campus/ [R=301,L]
RewriteRule ^dossier-dualdiploma\.html$ /dual-diploma/ [R=301,L]

# Compatibilidad con formularios que antes dependian de endpoints Vercel/Next.
RewriteRule ^api/(brevo-lead|send-enrollment|send-info-request)/?$ /enviar-formulario.php [L,QSA]

# Compresion gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# Cache de assets estaticos (el HTML no se cachea para poder publicar cambios al momento)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType application/pdf "access plus 7 days"
</IfModule>
